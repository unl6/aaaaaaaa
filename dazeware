-- ==================== MOVEMENT & ANTI-LOCK ====================
local Angle = 0
RunService.Heartbeat:Connect(function()
    if not Dazeware.Misc.AntiLock.Enabled then return end
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local oldCF = root.CFrame; local oldV = root.AssemblyLinearVelocity
    Angle = Angle + 1
    local desyncVel = Vector3.new(math.sin(Angle) * Dazeware.Misc.AntiLock.Strength, Dazeware.Misc.AntiLock.Strength, math.cos(Angle) * Dazeware.Misc.AntiLock.Strength)
    root.CFrame = oldCF * CFrame.Angles(0, math.rad(Angle * Dazeware.Misc.AntiLock.RotationSpeed), 0) * CFrame.new(0, 0, 1.5)
    root.AssemblyLinearVelocity = desyncVel
    RunService.RenderStepped:Wait()
    root.CFrame = oldCF
    root.AssemblyLinearVelocity = oldV
end)

local speedConnection = nil
local function ManageSpeedBypass(char)
    local hum = char:WaitForChild("Humanoid", 5)
    if not hum then return end
    if speedConnection then speedConnection:Disconnect() end
    speedConnection = hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
        local targetSpeed = Dazeware.Misc.WalkSpeed.Enabled and Dazeware.Misc.WalkSpeed.Speed or 16
        if hum.WalkSpeed ~= targetSpeed then hum.WalkSpeed = targetSpeed end
    end)
    task.spawn(function()
        while char and char.Parent and hum and hum.Parent do
            local targetSpeed = Dazeware.Misc.WalkSpeed.Enabled and Dazeware.Misc.WalkSpeed.Speed or 16
            if hum.WalkSpeed ~= targetSpeed then hum.WalkSpeed = targetSpeed end
            hum.JumpPower = Dazeware.Misc.SuperJump.Enabled and Dazeware.Misc.SuperJump.Power or 50
            if Dazeware.Misc.NoJumpCooldown.Enabled then hum.Jump = true end
            task.wait(0.1)
        end
    end)
end

if LocalPlayer.Character then ManageSpeedBypass(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(ManageSpeedBypass)

local function SortInventory()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return end
    local tools = {}
    for _, v in ipairs(backpack:GetChildren()) do if v:IsA("Tool") then table.insert(tools, v) end end
    table.sort(tools, function(a, b)
        local oa = table.find(Dazeware.Utilities.InventorySorter.Order, a.Name) or 999
        local ob = table.find(Dazeware.Utilities.InventorySorter.Order, b.Name) or 999
        return oa < ob
    end)
    for _, tool in ipairs(tools) do tool.Parent = backpack end
    Notify("Inventory Sorted!")
end

-- ==================== SILENT AIM (WITH PREDICTION FIXED) ====================
local mt = getrawmetatable(game)
local oldIndex = mt.__index
setreadonly(mt, false)

mt.__index = newcclosure(function(self, k)
    if Dazeware.SilentAim.Enabled and self == LocalPlayer:GetMouse() then
        local t = CurrentTarget
        if t and t.Character and IsValidTarget(t) then
            local hp = t.Character:FindFirstChild(Dazeware.SilentAim.HitPart) or t.Character:FindFirstChild("HumanoidRootPart")
            if hp then
                if k == "Hit" then
                    local pred = Dazeware.SilentAim.Prediction
                    local predictedPos = hp.Position + Vector3.new(
                        hp.Velocity.X * pred.X,
                        hp.Velocity.Y * pred.Y,
                        hp.Velocity.Z * pred.Z
                    )
                    if Dazeware.Misc.BulletTP.Enabled then
                        return CFrame.new(predictedPos + hp.Velocity * Dazeware.Misc.BulletTP.Strength)
                    end
                    return CFrame.new(predictedPos)
                elseif k == "Target" then
                    return hp
                end
            end
        end
    end
    return oldIndex(self, k)
end)

setreadonly(mt, true)

-- ==================== TARGET LINE ====================
local function CreateTargetLine()
    if targetLine then return end
    targetLine = Drawing.new("Line")
    targetLine.Thickness = 2; targetLine.Transparency = 0.8
end

local function UpdateTargetLine()
    if not targetLine or not Dazeware.SilentAim.TargetLine.Enabled or not Dazeware.SilentAim.Enabled then
        if targetLine then targetLine.Visible = false end
        return
    end
    local target = CurrentTarget
    if target and target.Character then
        local hp = target.Character:FindFirstChild(Dazeware.SilentAim.HitPart) or target.Character.HumanoidRootPart
        if hp then
            local mouse = UserInputService:GetMouseLocation()
            local w, on = Camera:WorldToViewportPoint(hp.Position)
            if on then
                targetLine.From = mouse
                targetLine.To = Vector2.new(w.X, w.Y)
                targetLine.Color = Dazeware.SilentAim.TargetLine.InFOV
                targetLine.Visible = true return
            end
        end
    end
    if targetLine then targetLine.Visible = false end
end
CreateTargetLine()

