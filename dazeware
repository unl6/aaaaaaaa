-- ==================== KNOCK CHECK ====================
local function IsValidTarget(plr)
    if not plr or not plr.Character or plr == LocalPlayer then return false end
    local char = plr.Character
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if not char:FindFirstChild("HumanoidRootPart") then return false end
    if hum:GetState() == Enum.HumanoidStateType.Dead then return false end
    if hum.PlatformStand == true then return false end
    
    local bodyEffects = char:FindFirstChild("BodyEffects")
    local function checkFlag(name)
        local obj = char:FindFirstChild(name) or (bodyEffects and bodyEffects:FindFirstChild(name))
        return obj and ((obj:IsA("BoolValue") and obj.Value == true) or (not obj:IsA("BoolValue") and not obj:IsA("NumberValue")))
    end
    
    if checkFlag("K.O") or checkFlag("KO") or checkFlag("Knocked") or checkFlag("Downed") or 
       checkFlag("Dead") or checkFlag("downed") or checkFlag("KO'd") or checkFlag("Stunned") then return false end
    
    if bodyEffects then
        local healthVal = bodyEffects:FindFirstChild("Health") or bodyEffects:FindFirstChild("health")
        if healthVal and healthVal:IsA("NumberValue") and healthVal.Value <= 0 then return false end
    end
    
    if char:FindFirstChild("GRABBING_CONSTRAINT") or char:FindFirstChild("Carried") then return false end
    return true
end

local function IsVisible(target)
    local myChar = LocalPlayer.Character
    local myHead = myChar and myChar:FindFirstChild("Head")
    local theirHead = target.Character and target.Character:FindFirstChild("Head")
    if not myHead or not theirHead then return false end
    local direction = (theirHead.Position - myHead.Position)
    if direction.Magnitude > 400 then return false end

    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {myChar, Camera}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.IgnoreWater = true
    local result = Workspace:Raycast(myHead.Position, direction, raycastParams)
    return not result or result.Instance:IsDescendantOf(target.Character)
end

local function GetClosestPlayer()
    local closest, dist = nil, math.huge
    local mousePos = UserInputService:GetMouseLocation()
    for _, plr in ipairs(Players:GetPlayers()) do
        if IsValidTarget(plr) then
            local root = plr.Character.HumanoidRootPart
            local pos = Camera:WorldToViewportPoint(root.Position)
            if pos.Z > 0 then
                local screenPos = Vector2.new(pos.X, pos.Y)
                local d = (screenPos - mousePos).Magnitude
                if d < dist then
                    dist = d
                    closest = plr
                end
            end
        end
    end
    return closest
end

local frameCount = 0
local function UpdateTarget()
    if not (Dazeware.SilentAim.Enabled or Dazeware.AimAssist.Enabled or Dazeware.TriggerBot.Enabled) then
        CurrentTarget = nil
        return
    end
    frameCount = frameCount + 1
    if frameCount % 3 ~= 0 then
        if CurrentTarget and IsValidTarget(CurrentTarget) then return end
    end
    if CurrentTarget and IsValidTarget(CurrentTarget) then
        return
    end
    CurrentTarget = GetClosestPlayer()
end

