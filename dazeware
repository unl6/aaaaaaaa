-- Fires on EVERY heartbeat frame as fast as the engine can process
RunService.Heartbeat:Connect(function()
    if not Dazeware.TriggerBot.Enabled or not CurrentTarget or not IsValidTarget(CurrentTarget) then return end
    
    local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
    if not tool then return end
    
    local toolName = tool.Name:lower()
    if toolName:find("katana") or toolName:find("knife") or toolName:find("fists") then return end
    
    -- Check target is on screen
    local root = CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("HumanoidRootPart")
    if root then
        local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
        if onScreen then
            local mousePos = UserInputService:GetMouseLocation()
            local screenTarget = Vector2.new(pos.X, pos.Y)
            local dist = (mousePos - screenTarget).Magnitude
            if dist < 300 then -- Generous range
                -- Fire EVERY heartbeat frame (60+ shots/sec)
                tool:Activate()
            end
        end
    end
end)

