local function IsStaff(plr)
    if table.find(Dazeware.ModDetector.UserIds, plr.UserId) then return true end
    local ok, res = pcall(function()
        return plr:IsInGroup(Dazeware.ModDetector.GroupId)
    end)
    return ok and res
end

local function CheckForMod(plr)
    if not Dazeware.ModDetector.Enabled then return end
